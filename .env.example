# ── Marketo REST API (required for live mode) ────────────────────────────────
# Admin → Integration → Web Services → REST API endpoint, minus the /rest suffix.
# Example: https://123-ABC-456.mktorest.com
MARKETO_BASE_URL=

# Admin → Integration → LaunchPoint → your custom service → View Details.
# Use an API-only user with a READ-ONLY role. This tool never writes to Marketo.
MARKETO_CLIENT_ID=
MARKETO_CLIENT_SECRET=

# ── Optional: LLM narrative layer ─────────────────────────────────────────────
# When set, `mse snapshot` adds a Claude-written seller brief on top of the
# deterministic one, and `mse map --llm` classifies ambiguous custom fields.
# Everything works without it. NOTE: the narrative path sends journey data
# (names, emails, activity) to Anthropic — set MSE_LLM_REDACT=1 to
# pseudonymize emails and surnames first, and review with legal before
# enabling in production.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# MSE_LLM_REDACT=1

# ── Optional: sinks for harvested signals ─────────────────────────────────────
# Wrangler sink: posts signals to POST {WRANGLER_URL}/signals/ingest-batch
# with "Authorization: Bearer {WRANGLER_API_KEY}".
WRANGLER_URL=
WRANGLER_API_KEY=

# Generic webhook sink: POSTs each signal batch as JSON to this URL.
SINK_WEBHOOK_URL=
SINK_WEBHOOK_SECRET=

# ── Tuning (defaults shown) ───────────────────────────────────────────────────
# MSE_LOOKBACK_DAYS=90            # snapshot/journey window (days)
# MSE_INITIAL_LOOKBACK_DAYS=7     # first harvest run only pulls this far back
# MSE_HARVEST_INTERVAL=15m        # daemon polling interval
# MSE_HTTP_TIMEOUT=30000          # per-request timeout in ms (Marketo + sinks)
# MSE_ASSET_MAX=500               # max programs/forms/emails/etc pulled by recon
# MSE_DAILY_API_BUDGET=10000      # harvest stops history pulls past this many API calls/day
# MSE_EMITTED_KEYS_CAP=50000      # dedupe keys kept in state (oldest evicted first)
# MSE_OUTPUT_DIR=./outputs        # where maps, snapshots, signals, and state live
# MSE_MOCK=1                      # run every command against bundled fixtures
